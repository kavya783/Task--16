<div class="container vh-100 d-flex justify-content-center align-items-center">

  <div class="card shadow-lg p-4 rounded-4" style="width: 600px;">

    <div class="text-center mb-4">
      <h4>Create your account</h4>
      <p class="text-secondary">Register hospital + user account</p>
    </div>

    <% if resource.errors.any? %>
      <div class="alert alert-danger">
        <ul class="mb-0">
          <% resource.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>

      <div class="row g-3">

        <div class="col-md-6">
          <%= f.label :hospital_name, class: "form-label fw-bold" %>
          <%= f.text_field :hospital_name,
              class: "form-control",
              placeholder: "Enter hospital name",
              required: true %>
        </div>

        <div class="col-md-6">
          <%= f.label :email, class: "form-label fw-bold" %>
          <%= f.email_field :email,
              class: "form-control",
              placeholder: "Enter email",
              required: true %>
        </div>

        <div class="col-md-6">
          <%= f.label :phone, class: "form-label fw-bold" %>
          <%= f.text_field :phone,
              class: "form-control",
              placeholder: "Enter phone number" %>
        </div>

        <div class="col-md-6">
          <%= f.label :city, class: "form-label fw-bold" %>
          <%= f.text_field :city,
              class: "form-control",
              placeholder: "Enter city" %>
        </div>

        <div class="col-md-6">
          <%= f.label :password, class: "form-label fw-bold" %>
          <%= f.password_field :password,
              class: "form-control",
              placeholder: "Enter password",
              autocomplete: "new-password",
              required: true %>

          <% if @minimum_password_length %>
            <small class="text-muted">
              Minimum <%= @minimum_password_length %> characters
            </small>
          <% end %>
        </div>

        <div class="col-md-6">
          <%= f.label :password_confirmation, class: "form-label fw-bold" %>
          <%= f.password_field :password_confirmation,
              class: "form-control",
              placeholder: "Confirm password",
              autocomplete: "new-password",
              required: true %>
        </div>

        <div class="col-12 d-grid mt-3">
          <%= f.submit "Sign Up",
              class: "btn btn-primary" %>
        </div>

      </div>

    <% end %>

    <hr>

    <div class="text-center">
      Already have an account?
      <%= link_to "Login",
          new_user_session_path,
          class: "text-decoration-none fw-bold" %>
    </div>

  </div>

</div>