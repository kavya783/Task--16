  <% if @mode == "appointment_table" %>
  <div class="card shadow-lg border-0 rounded-4 mt-4 ms-4">

  <!-- Header -->
  <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center rounded-top-4 " >
    <h5 class="mb-0">My Appointments</h5>
    <span class="badge bg-light text-dark">
      Total: <%= @appointments.size %>
    </span>
  </div>

  <div class="card-body p-0">

    <% if @appointments.any? %>

      <!-- ================= DESKTOP ================= -->
      <div class="d-none d-lg-block">

        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">

            <thead class="table-light">
              <tr>
                <th>Token</th>
                <th>Patient</th>
                <th>Date & Time</th>
                <th>Status</th>
                <th class="text-center">Actions</th>
              </tr>
            </thead>

            <tbody>
              <% @appointments.each do |appointment| %>

                <% status = appointment.status %>

                <tr>

                  <td>
                    <span class="badge bg-secondary">
                      #<%= appointment.token_number %>
                    </span>
                  </td>

                  <td>
                    <strong><%= appointment.patient&.name %></strong>
                  </td>

                  <td>
                    <%= appointment.scheduled_at&.strftime("%d %b %Y, %I:%M %p") %>
                  </td>

                  <td>
                    <% if status == "Upcoming" %>
                      <span class="badge bg-warning text-dark">Upcoming</span>
                    <% elsif status == "Completed" %>
                      <span class="badge bg-success">Completed</span>
                    <% elsif status == "Cancelled" %>
                      <span class="badge bg-danger">Cancelled</span>
                    <% else %>
                      <span class="badge bg-secondary"><%= status %></span>
                    <% end %>
                  </td>

                  <td>
                    <div class="d-flex justify-content-center gap-2 flex-wrap">

                      <button class="btn btn-sm btn-info"
                        data-bs-toggle="modal"
                        data-bs-target="#appointmentModal-<%= appointment.id %>">
                        View
                      </button>

                       <%= button_to "Conformed",
        update_status_hospital_appointment_path(appointment.hospital, appointment),
        params: { status: "Conformed" },
        method: :patch,
        form: { class: "d-inline" },
        class: appointment.status == "Conformed" ? "btn btn-warning btn-sm active" : "btn btn-outline-warning btn-sm" %>

    <%= button_to "Completed",
        update_status_hospital_appointment_path(appointment.hospital, appointment),
        params: { status: "Completed" },
        method: :patch,
        form: { class: "d-inline" },
        class: appointment.status == "Completed" ? "btn btn-success btn-sm active" : "btn btn-outline-success btn-sm" %>

    <%= button_to "Cancelled",
        update_status_hospital_appointment_path(appointment.hospital, appointment),
        params: { status: "Cancelled" },
        method: :patch,
        form: { class: "d-inline" },
        class: appointment.status == "Cancelled" ? "btn btn-danger btn-sm active" : "btn btn-outline-danger btn-sm" %>

                    </div>
                  </td>

                </tr>

              <% end %>
            </tbody>

          </table>
        </div>

      </div>

      <!-- ================= MOBILE ================= -->
      <div class="d-block d-lg-none p-3">

        <% @appointments.each do |appointment| %>

          <% status = appointment.status %>

          <div class="card mb-3 shadow-sm border-1 rounded-4">

            <div class="card-body">

              <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="badge bg-secondary">
                  #<%= appointment.token_number %>
                </span>

                <% if status == "Upcoming" %>
                  <span class="badge bg-warning text-dark">Upcoming</span>
                <% elsif status == "Completed" %>
                  <span class="badge bg-success">Completed</span>
                <% elsif status == "Cancelled" %>
                  <span class="badge bg-danger">Cancelled</span>
                <% else %>
                  <span class="badge bg-secondary"><%= status %></span>
                <% end %>
              </div>

              <p class="mb-1">
                <strong>Patient:</strong> <%= appointment.patient&.name %>
              </p>

              <p class="mb-1">
                <strong>Date:</strong>
                <%= appointment.scheduled_at&.strftime("%d %b %Y, %I:%M %p") %>
              </p>

              <div class="d-flex gap-1 mt-2 flex-wrap">

             <button class="btn btn-info btn-sm py-0 px-2 d-flex align-items-center mt-3"
        style="height: 30px; font-size: 11px;"
        data-bs-toggle="modal"
        data-bs-target="#appointmentModal-<%= appointment.id %>">
  View
</button>
                 <br>
               <div class="ms-0 gap-1 mt-3">
            <%= button_to "Confirmed",
        update_status_hospital_appointment_path(appointment.hospital, appointment),
        params: { status: "Confirmed" },
        method: :patch,
        form: { class: "d-inline" },
        class: appointment.status == "Confirmed" ? "btn btn-warning btn-sm active" : "btn btn-outline-warning btn-sm" %>

    <%= button_to "Complete",
        update_status_hospital_appointment_path(appointment.hospital, appointment),
        params: { status: "Completed" },
        method: :patch,
        form: { class: "d-inline" },
        class: appointment.status == "Completed" ? "btn btn-success btn-sm active" : "btn btn-outline-success btn-sm" %>

    <%= button_to "Cancel",
        update_status_hospital_appointment_path(appointment.hospital, appointment),
        params: { status: "Cancelled" },
        method: :patch,
        form: { class: "d-inline" },
        class: appointment.status == "Cancelled" ? "btn btn-danger btn-sm active" : "btn btn-outline-danger btn-sm" %>
       </div>


              </div>

            </div>
          </div>

        <% end %>

      </div>

    <% else %>

      <div class="text-center p-4">
        <p class="text-muted mb-0">No appointments found</p>
      </div>

    <% end %>

  </div>
</div>

              
  <% @appointments.each do |appointment| %>
    <div class="modal fade" id="appointmentModal-<%= appointment.id %>" tabindex="-1" aria-labelledby="appointmentModalLabel-<%= appointment.id %>" aria-hidden="true">
      <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="appointmentModalLabel-<%= appointment.id %>">Appointment Details</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">

    <!-- APPOINTMENT + PATIENT INFO -->
    <div class="row g-3">

      <!-- Appointment Card -->
      <div class="col-md-6">
      <div class="card p-3 h-100"
      style="box-shadow: 0 15px 10px rgba(0,0,0,0.08);">
          <h6 class="text-primary mb-3">Appointment Info</h6>

          <p class="mb-1"><strong>Token:</strong> <%= appointment.token_number %></p>
          <p class="mb-1"><strong>Scheduled:</strong> <%= appointment.scheduled_at&.strftime("%b %d, %Y %H:%M") %></p>
          <p class="mb-1"><strong>Status:</strong> <%= appointment.status %></p>
          <p class="mb-1"><strong>Type:</strong> <%= appointment.appointment_type %></p>
          <p class="mb-0"><strong>Reason:</strong> <%= appointment.reason %></p>
        </div>
      </div>

      <!-- Patient Card -->
      <div class="col-md-6">
        <div class="card p-3 h-100"
      style="box-shadow: 0 15px 10px rgba(0,0,0,0.08);">
          <h6 class="text-success mb-3">Patient Info</h6>

          <p class="mb-1"><strong>Name:</strong> <%= appointment.patient&.name %></p>
          <p class="mb-1"><strong>Email:</strong> <%= appointment.patient&.email %></p>
          <p class="mb-1"><strong>Phone:</strong> <%= appointment.patient&.phone %></p>
          <p class="mb-0"><strong>Hospital:</strong> <%= appointment.hospital&.name %></p>
        </div>
      </div>

    </div>

    <!-- PRESCRIPTIONS -->
  <div class="mt-4">

    <div class="d-flex justify-content-between align-items-center mb-2">
      <h6 class="text-dark mb-0">Prescriptions</h6>
    </div>

    <% if appointment.patient&.prescriptions&.any? %>

      <% appointment.patient.prescriptions.each do |prescription| %>
     
     
      <div class="mb-2"
     style="background:#fff;
            border:1px solid #e9ecef;
            border-radius:8px;
            box-shadow:0 10px 12px rgba(0,0,0,0.12);">


          <div class="card-body py-2 px-3">

            <div class="d-flex justify-content-between">
              <small class="text-muted">
              <strong>Date:</strong> <%= prescription.created_at.strftime("%d %b %Y") %>
              </small>

              <small class="text-primary">
                Dr. <%= prescription.doctor&.name %>
              </small>
            </div>
           
            <div class="d-flex justify-content-between">
            <div class="mt-1">
              <span class="text-dark">
                <strong>Prescription:</strong><%= prescription.prescription %>
              </span>
            </div>
           <%= button_to prescription_path(prescription),
    method: :delete,
    data: { turbo_confirm: "Are you sure?" },
    class: "btn btn-link text-danger p-0" do %>

  <i class="bi bi-trash3"></i>

<% end %>

</div>

          </div>

        </div>
        

      <% end %>

    <% else %>

      <div class="alert alert-info py-2 mb-0">
        No prescriptions found for this patient.
      </div>

    <% end %>

  </div>

  </div>  
          <div class="modal-footer">
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#prescriptionModal-<%= appointment.id %>" data-bs-dismiss="modal">Add Prescription</button>
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
          </div>
        </div>
      </div>
    </div>

    <div class="modal fade" id="prescriptionModal-<%= appointment.id %>" tabindex="-1" aria-labelledby="prescriptionModalLabel-<%= appointment.id %>" aria-hidden="true">
      <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="prescriptionModalLabel-<%= appointment.id %>">Add Prescription</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
           <%= form_with model: Prescription.new, url: prescriptions_path, method: :post, local: true do |form| %>  
              <%= form.hidden_field :patient_id, value: appointment.patient_id %>
              <%= hidden_field_tag :appointment_id, appointment.id %>

              <div class="mb-3">
                <%= form.label :prescription, "Prescription Details" %>
                <%= form.text_area :prescription, class: "form-control", rows: 5, placeholder: "Enter prescription details..." %>
              </div>
          </div>
          <div class="modal-footer">
              <%= form.submit "Save Prescription", class: "btn btn-success" %>
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <% end %>
          </div>
        </div>
      </div>
    </div>
    
  <% end %>

  <% end %>
  
  <% if @mode == "appointment_show" && @appointment %>
  <div class="container mt-4">
    <div class="card shadow p-4 mb-4 w-75 mx-auto">
      <h3>Appointment Details</h3>
      <p><strong>Patient:</strong> <%= @appointment.patient&.name %></p>
      <p><strong>Email:</strong> <%= @appointment.patient&.email %></p>
      <p><strong>Phone:</strong> <%= @appointment.patient&.phone %></p>
      <p><strong>Scheduled At:</strong> <%= @appointment.scheduled_at&.strftime("%b %d, %Y %H:%M") %></p>
      <p><strong>Type:</strong> <%= @appointment.appointment_type %></p>
      <p><strong>Reason:</strong> <%= @appointment.reason %></p>
      <p><strong>Status:</strong> <%= @appointment.status %></p>
      <p><strong>Token Number:</strong> <%= @appointment.token_number %></p>

      <div class="mt-4">
        <%= link_to "Back to Appointments",
            doctor_dashboard_path(current_doctor, mode: "appointment_table"),
            class: "btn btn-secondary" %> 
      </div>
    </div>

    <div class="card shadow p-4 w-75 mx-auto">
      <h3>Patient Prescriptions</h3>
      <% if @patient_prescriptions.any? %>
        <% @patient_prescriptions.each do |prescription| %>
          <div class="card mb-3">
            <div class="card-body">
              <p><strong>Date:</strong> <%= prescription.created_at.strftime("%b %d, %Y") %></p>
              <p><strong>Prescription:</strong></p>
              <p><%= prescription.prescription %></p>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="alert alert-info">No prescriptions found for this patient.</div>
      <% end %>
    </div>
  </div>
  <% end %>
