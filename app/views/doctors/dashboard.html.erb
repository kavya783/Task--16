              <span class="text-dark"><%= @doctor.city %></span>
            </p>

          </div>

        </div>

      
        <div class="col-md-6">

          <div class="p-3 bg-light rounded-4 h-100">

            <h6 class="text-muted mb-3">Professional Info</h6>

            <p class="mb-2">
              <strong>Specialization:</strong>
              <span class="badge bg-primary">
                <%= @doctor.specialization %>
              </span>
