        <th  class="text-center">Doctor</th>
        <th  class="text-center">Date & Time</th>
        <th  class="text-center">Status</th>
        <th  class="text-center">Type</th>
        <th  class="text-center">Actions</th>
      </tr>
    </thead>

    <tbody>

      <% @appointments.each do |appointment| %>

        <tr>

          <td class="fw-semibold text-center">
            <%= appointment.patient&.name %>
          </td>

          <td class=" text-center">
            <%= appointment.doctor&.name %>
          </td>

          <td class=" text-center">
            <%= appointment.scheduled_at&.strftime("%d %b %Y, %I:%M %p") %>
          </td>

          <td class=" text-center">
            <% if appointment.status == "Completed" %>
              <span class="badge bg-success">
                Completed
              </span>
            <% elsif appointment.status == "Cancelled" %>
              <span class="badge bg-danger">
                Cancelled
              </span>
            <% else %>
              <span class="badge bg-warning text-dark">
                <%= appointment.status %>
              </span>
            <% end %>
          </td>

          <td class=" text-center">
            <span class="badge bg-info text-dark">
              <%= appointment.appointment_type %>
            </span>
          </td>

          <td class="text-center">

            <div class="d-flex justify-content-center gap-1 flex-wrap">

              <%= link_to "View",
                  hospital_path(@hospital,
                  mode: "appointment_show",
                  appointment_id: appointment.id),
                  class: "btn btn-info btn-sm" %>

              <%= link_to "Edit",
                  hospital_path(@hospital,
                  mode: "appointment_edit",
                  appointment_id: appointment.id),
                  class: "btn btn-warning btn-sm" %>

              <%= button_to "Delete",
                  hospital_appointment_path(@hospital, appointment),
                  method: :delete,
                  data: { turbo_confirm: "Delete this appointment?" },
                  class: "btn btn-danger btn-sm" %>

            </div>

          </td>

        </tr>

      <% end %>

    </tbody>

  </table>

</div>
        <% else %>
          <p class="text-center mt-3">No appointments found.</p>
        <% end %>
      </div>
    </div>
  </div>

 <div class="d-block d-md-none">

  <div class="card border-0 shadow-sm rounded-4 mb-3">

    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">

      <h6 class="mb-0">
        Appointments
      </h6>

      <%= link_to hospital_path(@hospital, mode: "appointment_form"),
          class: "btn btn-light btn-sm" do %>

        <i class="bi bi-plus"></i>

      <% end %>

    </div>

  </div>

  <% @appointments.each do |appointment| %>

    <div class="card border-1 shadow-sm rounded-4 mb-3">

      <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-2">

          <h6 class="fw-bold mb-0">
          <strong>Name:</strong>
            <%= appointment.patient&.name %>
          </h6>

          <span class="badge bg-secondary">
            <%= appointment.appointment_type %>
          </span>

        </div>

        <p class="mb-1">
          <strong>Doctor:</strong>
          <%= appointment.doctor&.name %>
        </p>

        <p class="mb-1">
          <strong>Date:</strong>
          <%= appointment.scheduled_at&.strftime("%d %b %Y, %I:%M %p") %>
        </p>

        <p class="mb-2">
          <strong>Status:</strong>

          <% if appointment.status == "Completed" %>
            <span class="badge bg-success">Completed</span>
          <% elsif appointment.status == "Cancelled" %>
            <span class="badge bg-danger">Cancelled</span>
          <% else %>
            <span class="badge bg-warning text-dark">
              <%= appointment.status %>
            </span>
          <% end %>
        </p>

        <p>
        <strong>Reason:</strong>
          <%= appointment.reason.presence || "No reason provided" %>
        </p>

        <div class="d-flex gap-2">

          <%= link_to "View",
              hospital_path(@hospital,
              mode: "appointment_show",
              appointment_id: appointment.id),
              class: "btn btn-info btn-sm flex-fill" %>

          <%= link_to "Edit",
              hospital_path(@hospital,
              mode: "appointment_edit",
              appointment_id: appointment.id),
              class: "btn btn-warning btn-sm flex-fill" %>

        </div>

        <div class="mt-2">

          <%= button_to "Delete",
              hospital_appointment_path(@hospital, appointment),
              method: :delete,
              data: { turbo_confirm: "Delete this appointment?" },
              class: "btn btn-danger btn-sm w-100" %>

        </div>

      </div>

    </div>

  <% end %>

</div>
<% end %>
<% if @mode == "appointment_form" || @mode == "appointment_edit" %>

<div class="container py-4">

  <div class="row justify-content-center">
    <div class="col-lg-8">

      <div class="card border-0 shadow-lg rounded-4">

        <!-- Header -->
        <div class="card-header bg-primary text-white rounded-top-4">
          <h4 class="mb-0">
            <i class="bi bi-calendar-check me-2"></i>
            <%= @mode == "appointment_edit" ? "Edit Appointment" : "New Appointment" %>
          </h4>
        </div>

        <div class="card-body p-4">

          <% if @appointment&.errors&.any? %>
            <div class="alert alert-danger rounded-3">
              <h6 class="fw-bold">Please fix the following errors:</h6>
              <ul class="mb-0">
                <% @appointment.errors.full_messages.each do |msg| %>
                  <li><%= msg %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <%= form_with model: @appointment,
              url: @mode == "appointment_edit" ?
              hospital_appointment_path(@hospital, @appointment) :
              hospital_appointments_path(@hospital),
              method: @mode == "appointment_edit" ? :patch : :post,
              local: true do |f| %>

            <div class="row g-3">

              <div class="col-md-6">
                <%= f.label :patient_id, "Patient", class: "form-label fw-semibold" %>
                <%= f.collection_select :patient_id,
                    @hospital.patients,
                    :id,
                    :name,
                    { prompt: "Select Patient" },
                    class: "form-select" %>
              </div>

              <div class="col-md-6">
                <%= f.label :doctor_id, "Doctor", class: "form-label fw-semibold" %>
                <%= f.collection_select :doctor_id,
                    @hospital.doctors,
                    :id,
                    :name,
                    { prompt: "Select Doctor" },
                    class: "form-select" %>
              </div>

              <div class="col-md-6">
                <%= f.label :scheduled_at, class: "form-label fw-semibold" %>
                <%= f.datetime_local_field :scheduled_at,
                    class: "form-control" %>
              </div>

              <div class="col-md-6">
                <%= f.label :appointment_type, class: "form-label fw-semibold" %>
                <%= f.select :appointment_type,
                    ["Normal", "Follow Up", "Emergency"],
                    { prompt: "Select Type" },
                    class: "form-select" %>
              </div>

              <div class="col-md-6">
                <%= f.label :token_number, class: "form-label fw-semibold" %>
                <%= f.number_field :token_number,
                    class: "form-control",
                    placeholder: "Enter token number" %>
              </div>

              <div class="col-12">
                <%= f.label :reason, class: "form-label fw-semibold" %>
                <%= f.text_area :reason,
                    rows: 4,
                    class: "form-control",
                    placeholder: "Enter appointment reason..." %>
              </div>

            </div>

            <!-- Buttons -->
            <div class="d-flex flex-column flex-md-row gap-2 justify-content-end mt-4">

              <%= link_to hospital_path(@hospital, mode: "appointment_table"),
                  class: "btn btn-outline-secondary px-4" do %>
                <i class="bi bi-arrow-left"></i> Back
              <% end %>

              <%= f.submit @mode == "appointment_edit" ?
                  "Update Appointment" :
                  "Create Appointment",
                  class: "btn btn-success px-4" %>

            </div>

          <% end %>

        </div>

      </div>

    </div>
  </div>

</div>

<% end %>

<% if @mode == "appointment_show" && @appointment %>
  <div class="container d-flex justify-content-center mt-5 mb-3">
    <div class="card shadow p-4 w-75">
      <h3>Appointment Details</h3>
      <p><strong>Patient:</strong> <%= @appointment.patient&.name %></p>
      <p><strong>Doctor:</strong> <%= @appointment.doctor&.name %></p>
      <p><strong>Scheduled At:</strong> <%= @appointment.scheduled_at ? @appointment.scheduled_at.strftime("%b %d, %Y %H:%M") : "Not scheduled" %></p>
      <p><strong>Status:</strong> <%= @appointment.status.presence || "N/A" %></p>
      <p><strong>Notes:</strong> <%= @appointment.reason.presence || "-" %></p>

      <div class="d-flex gap-2 mt-3">
        <%= link_to "Back",
            hospital_path(@hospital, mode: "appointment_table"),
            class: "btn btn-secondary" %>
        <%= link_to "Edit",
            hospital_path(@hospital, mode: "appointment_edit", appointment_id: @appointment.id),
            class: "btn btn-primary" %>
      </div>
    </div>
  </div>
<% end %>

<% if params[:mode] == "patient_show" && @patient %>

<div class="container d-flex justify-content-center mt-5">
  <div class="card shadow p-4 w-75">

    <h3>Patient Details</h3>

    <p><strong>Name:</strong> <%= @patient.name %></p>
    <p><strong>Email:</strong> <%= @patient.email %></p>
    <p><strong>Age:</strong> <%= @patient.age %></p>
    <p><strong>Disease:</strong> <%= @patient.disease %></p>
    <p><strong>Phone:</strong> <%= @patient.phone %></p>
  

    <%= link_to "Back",
        hospital_path(@hospital, mode: "patient_table"),
        class: "btn btn-secondary mt-2" %>

  </div>
</div>

<% end %>